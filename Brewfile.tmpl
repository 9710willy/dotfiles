# Brewfile - managed by chezmoi
# Machine context: {{ .machine.context }}

# =============================================================================
# Taps
# =============================================================================
tap "fsouza/prettierd"

# =============================================================================
# Core Tools (all machines)
# =============================================================================
brew "chezmoi"
brew "neovim"
brew "tmux"

# Shell enhancements
brew "bat"
brew "direnv"
brew "eza"
brew "fzf"
brew "lazygit"
brew "mise"
brew "tlrc"
brew "zoxide"
brew "git-delta"

# Search & navigation
brew "ripgrep"
brew "fd"
brew "tree"

# Useful CLI tools
brew "gh"        # GitHub CLI
brew "jq"        # JSON processor

# =============================================================================
# Development Tools (all machines)
# =============================================================================

# Language servers & formatters
brew "ltex-ls"
brew "lua-language-server"
brew "marksman"
brew "prettierd"
brew "selene"
brew "yaml-language-server"

# Docker
brew "colima"
brew "docker"

# CLI utilities & dev tooling
brew "btop"
brew "ffmpeg"
brew "git-filter-repo"
brew "go"
brew "pinentry-mac"
brew "pipx"
brew "plantuml"
brew "poppler"
brew "shellcheck"
brew "shfmt"
brew "stylua"
brew "swaks"
brew "yt-dlp"

# =============================================================================
# GUI Apps (all machines)
# =============================================================================
cask "ghostty"
cask "font-jetbrains-mono-nerd-font"  # ghostty font-family depends on this
cask "karabiner-elements"
cask "raycast"
cask "rectangle"

{{- if eq .machine.context "company" }}

# =============================================================================
# Company machine tools
# =============================================================================
brew "ant"
brew "glab"
brew "gradle@7"
brew "mysql"
brew "nginx"
brew "pam-u2f"
brew "ykman"
brew "ykpers"
cask "gcloud-cli"
cask "kiwix"
cask "libreoffice"
cask "mysqlworkbench"

{{- end }}

{{- if eq .machine.context "personal" }}

# =============================================================================
# Personal machine tools
# =============================================================================

